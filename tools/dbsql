#!/usr/bin/env python3
"""Run SQL against the hackathon warehouse. Usage: tools/dbsql "SELECT 1" [--json]"""
import json
import subprocess
import sys
import time

WAREHOUSE = "4c8cec5ddedd872b"


def api(method, path, payload=None):
    cmd = ["databricks", "api", method, path, "--profile", "hackathon"]
    if payload is not None:
        cmd += ["--json", json.dumps(payload)]
    p = subprocess.run(cmd, capture_output=True, text=True)
    if p.returncode != 0:
        sys.stderr.write(p.stderr)
        sys.exit(1)
    return json.loads(p.stdout)


def run(sql):
    d = api("post", "/api/2.0/sql/statements", {
        "warehouse_id": WAREHOUSE, "statement": sql, "wait_timeout": "50s",
        "format": "JSON_ARRAY", "disposition": "INLINE",
    })
    while d.get("status", {}).get("state") in ("PENDING", "RUNNING"):
        time.sleep(3)
        d = api("get", f"/api/2.0/sql/statements/{d['statement_id']}")
    return d


def main():
    sql = sys.argv[1]
    as_json = "--json" in sys.argv
    d = run(sql)
    state = d.get("status", {}).get("state")
    if state != "SUCCEEDED":
        print(json.dumps(d.get("status", {}), indent=2))
        sys.exit(2)
    cols = [c["name"] for c in d.get("manifest", {}).get("schema", {}).get("columns", [])]
    rows = d.get("result", {}).get("data_array", [])
    if as_json:
        print(json.dumps([dict(zip(cols, r)) for r in rows], indent=1))
    else:
        print(" | ".join(cols))
        for r in rows:
            print(" | ".join("∅" if v is None else str(v)[:120] for v in r))


if __name__ == "__main__":
    main()
